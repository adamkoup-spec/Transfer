if __name__ == "__main__":
    metrics_df = evaluate_all_results()
    metrics_df.to_csv(OUTPUT_DIR / "stress_test_metrics_by_doc_type.csv", index=False)

    degradation_df = add_degradation_vs_baseline(metrics_df, baseline_name="Baseline")

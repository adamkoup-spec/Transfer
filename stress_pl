        title=f"Rollup Coverage Rate by Doc Type at Confidence ≥ {CONFIDENCE_THRESHOLD}",
        output_path=OUTPUT_DIR / "rollup_coverage_by_doc_type.png",
    )

    # Degradation plots by doc type
    plot_degradation_delta(
        degradation_df,

    plot_degradation_delta(
        degradation_df,
        metric_delta="rollup_accuracy_delta_vs_baseline",
        title="Rollup Accuracy Degradation vs Baseline",
        output_path=OUTPUT_DIR / "rollup_accuracy_degradation_vs_baseline.png",

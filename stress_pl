        title="Child-Level Accuracy Degradation vs Baseline",
        output_path=OUTPUT_DIR / "child_accuracy_degradation_vs_baseline.png",
    )

    plot_degradation_delta(
        degradation_df,
        metric_delta="child_coverage_rate_delta_vs_baseline",
        title="Child-Level Coverage Rate Degradation vs Baseline",
        output_path=OUTPUT_DIR / "child_coverage_degradation_vs_baseline.png",

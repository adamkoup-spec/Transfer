import json
from pathlib import Path
from typing import Any, Dict, List
import pandas as pd


RESULTS_ROOT = Path("/path/to/results")
GROUND_TRUTH_ROOT = Path("/path/to/ground_truth")

ROUTES_BY_FOLDER = {
    "A": "response.output",
    "B": "prediction.final",
    "C": "data.items",
}

ENTITY_KEY = "entity_name"
VALUE_KEY = "value"

STRIP_STRINGS = True
CASE_INSENSITIVE_STRINGS = False


def load_json(path: Path) -> Any:
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f)


def normalize_value(x: Any) -> Any:
    if isinstance(x, str):
        if STRIP_STRINGS:
            x = x.strip()
        if CASE_INSENSITIVE_STRINGS:
            x = x.lower()
    return x


def get_by_route(obj: Any, route: str) -> Any:
    cur = obj
    for part in route.split("."):
        if isinstance(cur, dict):
            if part not in cur:
                return None
            cur = cur[part]
        elif isinstance(cur, list):
            if not part.isdigit():
                return None
            idx = int(part)
            if idx < 0 or idx >= len(cur):
                return None
            cur = cur[idx]
        else:
            return None
    return cur


def extract_value(x: Any, value_key: str = VALUE_KEY) -> Any:
    if isinstance(x, dict):
        return x.get(value_key)
    return x


def list_relative_jsons(folder: Path) -> List[Path]:
    return sorted([p.relative_to(folder) for p in folder.rglob("*.json")])


def extract_record_fields(record: Dict[str, Any]) -> Dict[str, Any]:
    """
    Input example:
    {
        "entity_name": {"value": "Apple"},
        "ticker": {"value": "AAPL"},
        "country": {"value": "US"}
    }

    Output:
    {
        "entity_name": "Apple",
        "ticker": "AAPL",
        "country": "US"
    }
    """
    out = {}
    for k, v in record.items():
        out[k] = normalize_value(extract_value(v))
    return out


def build_folder_dataframe(
    folder_name: str,
    result_folder: Path,
    gt_folder: Path,
    route: str,
) -> pd.DataFrame:
    result_files = set(list_relative_jsons(result_folder))
    gt_files = set(list_relative_jsons(gt_folder))

    common_files = sorted(result_files & gt_files)
    rows = []

    # matched files
    for rel_path in common_files:
        pred_path = result_folder / rel_path
        gt_path = gt_folder / rel_path

        row = {
            "folder": folder_name,
            "file": str(rel_path),
            "status": "OK",
        }

        try:
            pred_json = load_json(pred_path)
            gt_json = load_json(gt_path)
        except Exception as e:
            row["status"] = f"ERROR reading file: {e}"
            rows.append(row)
            continue

        pred_record = get_by_route(pred_json, route)
        gt_record = get_by_route(gt_json, route)

        if pred_record is None:
            row["status"] = "Missing route in prediction"
            rows.append(row)
            continue

        if gt_record is None:
            row["status"] = "Missing route in ground truth"
            rows.append(row)
            continue

        if not isinstance(pred_record, dict) or not isinstance(gt_record, dict):
            row["status"] = "Route does not point to dict in both files"
            rows.append(row)
            continue

        pred_fields = extract_record_fields(pred_record)
        gt_fields = extract_record_fields(gt_record)

        all_fields = sorted(set(pred_fields.keys()) | set(gt_fields.keys()))

        matched_fields = 0
        total_fields = 0

        for field in all_fields:
            gt_val = gt_fields.get(field)
            pred_val = pred_fields.get(field)

            row[f"{field}_gt"] = gt_val
            row[f"{field}_pred"] = pred_val
            row[f"{field}_match"] = (gt_val == pred_val)

            total_fields += 1
            if gt_val == pred_val:
                matched_fields += 1

        row["matched_fields"] = matched_fields
        row["total_fields"] = total_fields
        row["row_accuracy"] = matched_fields / total_fields if total_fields else None

        rows.append(row)

    # missing in GT
    for rel_path in sorted(result_files - gt_files):
        rows.append({
            "folder": folder_name,
            "file": str(rel_path),
            "status": "Missing in ground truth",
        })

    # missing in prediction
    for rel_path in sorted(gt_files - result_files):
        rows.append({
            "folder": folder_name,
            "file": str(rel_path),
            "status": "Missing in prediction",
        })

    df = pd.DataFrame(rows)

    if df.empty:
        return df

    # nice column ordering
    first_cols = [
        "folder", "file", "status",
        f"{ENTITY_KEY}_gt", f"{ENTITY_KEY}_pred", f"{ENTITY_KEY}_match",
        "matched_fields", "total_fields", "row_accuracy"
    ]
    first_cols = [c for c in first_cols if c in df.columns]

    paired_cols = []
    base_names = sorted({
        c[:-3] for c in df.columns if c.endswith("_gt")
    } | {
        c[:-5] for c in df.columns if c.endswith("_pred")
    } | {
        c[:-6] for c in df.columns if c.endswith("_match")
    })

    # Put entity_name first, others after
    base_names = [b for b in base_names if b != ENTITY_KEY]
    for base in base_names:
        for suffix in ["_gt", "_pred", "_match"]:
            col = f"{base}{suffix}"
            if col in df.columns and col not in first_cols:
                paired_cols.append(col)

    remaining_cols = [
        c for c in df.columns
        if c not in first_cols and c not in paired_cols
    ]

    df = df[first_cols + paired_cols + remaining_cols]
    df = df.sort_values(["file"], na_position="last").reset_index(drop=True)

    return df


def build_all_tables(
    results_root: Path,
    gt_root: Path,
    routes_by_folder: Dict[str, str],
) -> Dict[str, pd.DataFrame]:
    tables_by_folder = {}

    for folder_name, route in routes_by_folder.items():
        result_folder = results_root / folder_name
        gt_folder = gt_root / folder_name

        if not result_folder.exists():
            tables_by_folder[folder_name] = pd.DataFrame([{
                "folder": folder_name,
                "file": None,
                "status": f"Missing results folder: {result_folder}",
            }])
            continue

        if not gt_folder.exists():
            tables_by_folder[folder_name] = pd.DataFrame([{
                "folder": folder_name,
                "file": None,
                "status": f"Missing ground truth folder: {gt_folder}",
            }])
            continue

        df = build_folder_dataframe(
            folder_name=folder_name,
            result_folder=result_folder,
            gt_folder=gt_folder,
            route=route,
        )
        tables_by_folder[folder_name] = df

    return tables_by_folder


def build_summary_table(tables_by_folder: Dict[str, pd.DataFrame]) -> pd.DataFrame:
    summary_rows = []

    for folder_name, df in tables_by_folder.items():
        if df.empty:
            summary_rows.append({
                "folder": folder_name,
                "files_compared": 0,
                "field_accuracy": None,
                "exact_match_rate": None,
            })
            continue

        ok_df = df[df["status"] == "OK"].copy()

        if ok_df.empty:
            summary_rows.append({
                "folder": folder_name,
                "files_compared": 0,
                "field_accuracy": None,
                "exact_match_rate": None,
            })
            continue

        exact_matches = (ok_df["matched_fields"] == ok_df["total_fields"]).sum()
        files_compared = len(ok_df)
        total_matched = ok_df["matched_fields"].sum()
        total_fields = ok_df["total_fields"].sum()

        summary_rows.append({
            "folder": folder_name,
            "files_compared": files_compared,
            "field_accuracy": total_matched / total_fields if total_fields else None,
            "exact_match_rate": exact_matches / files_compared if files_compared else None,
        })

    return pd.DataFrame(summary_rows)


if __name__ == "__main__":
    tables_by_folder = build_all_tables(
        results_root=RESULTS_ROOT,
        gt_root=GROUND_TRUTH_ROOT,
        routes_by_folder=ROUTES_BY_FOLDER,
    )

    summary_df = build_summary_table(tables_by_folder)

    # save each folder table separately
    for folder_name, df in tables_by_folder.items():
        out_path = f"comparison_{folder_name}.csv"
        df.to_csv(out_path, index=False)
        print(f"Saved {out_path}")

    summary_df.to_csv("comparison_summary.csv", index=False)
    print("Saved comparison_summary.csv")

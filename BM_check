def ordered_models_present(df: pd.DataFrame) -> List[str]:
    return [m for m in MODEL_ORDER if m in set(df["model"])]


def plot_metric_by_doc_type(
    df: pd.DataFrame,
    metric: str,
    title: str,
    output_path: Path,
) -> None:
    pivot = df.pivot(index="doc_type", columns="model", values=metric)

    cols = [m for m in MODEL_ORDER if m in pivot.columns]
    pivot = pivot[cols]

    ax = pivot.plot(kind="bar", figsize=(13, 6))
    ax.set_title(title)
    ax.set_xlabel("Doc Type")
    ax.set_ylabel(metric.replace("_", " ").title())
    ax.set_ylim(0, 1)
    ax.legend(title="Model", bbox_to_anchor=(1.02, 1), loc="upper left")
    plt.tight_layout()
    plt.savefig(output_path, dpi=150)
    plt.close()


def plot_overall_metric(
    overall_df: pd.DataFrame,
    metric: str,
    title: str,
    output_path: Path,
) -> None:
    plot_df = overall_df.set_index("model")
    plot_df = plot_df.loc[[m for m in MODEL_ORDER if m in plot_df.index]]

    ax = plot_df[metric].plot(kind="bar", figsize=(11, 5))
    ax.set_title(title)
    ax.set_xlabel("Model")
    ax.set_ylabel(metric.replace("_", " ").title())
    ax.set_ylim(0, 1)
    plt.tight_layout()
    plt.savefig(output_path, dpi=150)
    plt.close()


def plot_delta_vs_production(
    delta_df: pd.DataFrame,
    metric_delta: str,
    title: str,
    output_path: Path,
) -> None:
    plot_df = delta_df[delta_df["model"] != PRODUCTION_NAME].copy()

    pivot = plot_df.pivot(index="doc_type", columns="model", values=metric_delta)
    cols = [m for m in MODEL_ORDER if m != PRODUCTION_NAME and m in pivot.columns]
    pivot = pivot[cols]

    ax = pivot.plot(kind="bar", figsize=(13, 6))
    ax.axhline(0, linewidth=1)
    ax.set_title(title)
    ax.set_xlabel("Doc Type")
    ax.set_ylabel("Delta vs Production")
    ax.legend(title="Model", bbox_to_anchor=(1.02, 1), loc="upper left")
    plt.tight_layout()
    plt.savefig(output_path, dpi=150)
    plt.close()


def plot_coverage_accuracy_scatter(
    overall_df: pd.DataFrame,
    output_path: Path,
    use_rollup: bool = False,
) -> None:
    if use_rollup:
        coverage_col = "rollup_coverage_rate"
        accuracy_col = "rollup_accuracy"
        title = "Overall Rollup Accuracy vs Coverage Rate"
    else:
        coverage_col = "child_coverage_rate"
        accuracy_col = "child_accuracy"
        title = "Overall Child-Level Accuracy vs Coverage Rate"

    fig, ax = plt.subplots(figsize=(8, 6))

    for _, row in overall_df.iterrows():
        x = row[coverage_col]
        y = row[accuracy_col]
        if pd.isna(x) or pd.isna(y):
            continue
        ax.scatter(x, y)
        ax.annotate(row["model"], (x, y), xytext=(5, 5), textcoords="offset points")

    ax.set_title(title)
    ax.set_xlabel("Coverage Rate")
    ax.set_ylabel("Accuracy")
    ax.set_xlim(0, 1)
    ax.set_ylim(0, 1)
    plt.tight_layout()
    plt.savefig(output_path, dpi=150)
    plt.close()


